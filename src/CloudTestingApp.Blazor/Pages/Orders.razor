@page "/orders"
@using CloudTestingApp.Application.DTOs
@using CloudTestingApp.Domain.Entities
@inject HttpClient Http

<h3>Orders</h3>

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (orders == null && errorMessage == null)
{
    <p><em>Loading...</em></p>
}
else if (orders != null)
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Customer</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in orders)
            {
                <tr>
                    <td>@order.Id.ToString().Substring(0, 8)...</td>
                    <td>@order.CustomerName</td>
                    <td>@order.TotalAmount.ToString("C")</td>
                    <td>@order.Status</td>
                    <td>@order.CreatedAt.ToString("g")</td>
                </tr>
            }
        </tbody>
    </table>
}

<hr />
<h4>Create New Order</h4>
<div class="form-group">
    <label>Customer Name:</label>
    <input @bind="newOrder.CustomerName" class="form-control" />
</div>
<div class="form-group">
    <label>Total Amount:</label>
    <input @bind="newOrder.TotalAmount" type="number" class="form-control" />
</div>
<button @onclick="CreateOrder" class="btn btn-primary mt-2">Create Order</button>

@code {
    private IEnumerable<OrderDto>? orders;
    private CreateOrderRequest newOrder = new("", 0);
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        try
        {
            errorMessage = null;
            orders = await Http.GetFromJsonAsync<IEnumerable<OrderDto>>("api/orders");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading orders: {ex.Message}";
        }
    }

    private async Task CreateOrder()
    {
        try
        {
            errorMessage = null;
            var response = await Http.PostAsJsonAsync("api/orders", newOrder);
            if (response.IsSuccessStatusCode)
            {
                newOrder = new("", 0);
                await LoadOrders();
            }
            else
            {
                errorMessage = $"Error creating order: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating order: {ex.Message}";
        }
    }
}
